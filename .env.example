# Application display name used in the UI and Swagger.
APP_NAME=SuperBookmarks

# Application port used by the NestJS server.
PORT=3000

# MongoDB connection string used by Mongoose.
MONGO_URI=mongodb://mongo:27017/score-dashboard

# Basic authentication username for dashboard pages and APIs.
BASIC_AUTH_USERNAME=admin

# Basic authentication password for dashboard pages and APIs.
BASIC_AUTH_PASSWORD=admin

# Basic authentication realm shown by the browser challenge dialog.
BASIC_AUTH_REALM=SuperBookmarks

# Default UI theme applied to the rendered pages.
DEFAULT_THEME=dark

# Swagger route path for API documentation.
SWAGGER_PATH=docs

# Default app prefixes loaded into settings on the first boot.
DEFAULT_APP_PREFIXES=[{"label":"VS Code","prefix":"vscode://file/"},{"label":"Cursor","prefix":"cursor://"}]
